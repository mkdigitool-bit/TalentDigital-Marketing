---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

import pfAvocats from '../assets/portfolio/avocats.jpg';
import pfDentaire from '../assets/portfolio/dentaire.jpg';
import pfClinique from '../assets/portfolio/clinique.jpg';
import pfEntreprise from '../assets/portfolio/entreprise.jpg';
import pfBtp from '../assets/portfolio/btp.jpg';
import pfArtisan from '../assets/portfolio/artisan.jpg';
import pfImmobilier from '../assets/portfolio/immobilier.jpg';
import pfRestaurant from '../assets/portfolio/restaurant.jpg';
import pfFleuriste from '../assets/portfolio/fleuriste.jpg';
import pfBeaute from '../assets/portfolio/beaute.jpg';
import pfPaysagiste from '../assets/portfolio/paysagiste.jpg';
import pfDecoration from '../assets/portfolio/decoration.jpg';
import pfEvenementiel from '../assets/portfolio/evenementiel.jpg';

const portfolioItems = [
  { img: pfAvocats, label: 'Cabinets d\'avocats' },
  { img: pfDentaire, label: 'Cabinets dentaires' },
  { img: pfClinique, label: 'Cliniques médicales' },
  { img: pfEntreprise, label: 'Entreprises & PME' },
  { img: pfBtp, label: 'BTP & construction' },
  { img: pfArtisan, label: 'Artisans traditionnels' },
  { img: pfImmobilier, label: 'Agences immobilières' },
  { img: pfRestaurant, label: 'Restaurants' },
  { img: pfFleuriste, label: 'Fleuristes' },
  { img: pfBeaute, label: 'Centres de beauté' },
  { img: pfPaysagiste, label: 'Paysagistes' },
  { img: pfDecoration, label: 'Décoration intérieure' },
  { img: pfEvenementiel, label: 'Événementiel' },
];
---

<BaseLayout title="TalentDigital — Sites, tunnels de vente &amp; landing pages haute conversion" description="Studio indépendant spécialisé en sites web, tunnels de vente et landing pages haute conversion pour coachs, formateurs, e-commerçants et infopreneurs. Audit gratuit, réponse sous 24 h.">

<section class="hero wrap">
  <span class="hero__badge"><span class="live" aria-hidden="true"></span> Système opérationnel — présence mondiale</span>
  <div class="hero__grid">
    <div>
      <h1 class="reveal">Des sites et tunnels conçus pour <em>convertir</em>, pas pour décorer.</h1>
      <p class="hero__sub lede reveal">Sites web, tunnels de vente et landing pages haute conversion pour entrepreneurs, professionnels et commerces qui veulent convertir plus de visiteurs en clients. Une infrastructure digitale taillée pour vos chiffres — pas pour votre ego.</p>
      <div class="hero__cta reveal">
        <a href="#contact" class="btn">Réserver un audit gratuit <span class="arr">→</span></a>
        <span class="hero__micro"><b>Réponse sous 24 h</b> · Sans engagement</span>
      </div>
    </div>
    <div class="console reveal" aria-label="Indicateurs de performance">
      <div class="console__bar" aria-hidden="true">
        <span class="console__dot"></span><span class="console__dot"></span><span class="console__dot on"></span>
        <span class="console__name">résultats.live</span>
      </div>
      <div class="console__body">
        <div class="metric">
          <div class="metric__top">
            <span class="metric__label">taux_ouverture_email</span>
            <span class="metric__val">42<span class="u">%</span></span>
          </div>
          <div class="metric__bar"><div class="metric__fill" data-w="84"></div></div>
        </div>
        <div class="metric">
          <div class="metric__top">
            <span class="metric__label">délai_livraison</span>
            <span class="metric__val">7<span class="u">j</span></span>
          </div>
          <div class="metric__bar"><div class="metric__fill" data-w="70"></div></div>
        </div>
        <div class="metric">
          <div class="metric__top">
            <span class="metric__label">projets_livrés</span>
            <span class="metric__val">120<span class="u">+</span></span>
          </div>
          <div class="metric__bar"><div class="metric__fill" data-w="92"></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section wrap" id="portfolio">
  <div class="section__head reveal">
    <span class="prompt">01 — <b>portfolio</b></span>
    <h2>Un site pensé pour votre <em>secteur</em>, pas un template générique.</h2>
    <p class="lede" style="margin-top:1rem">Chaque activité a ses propres leviers de conversion. Voici comment ça se traduit concrètement selon votre métier.</p>
  </div>
  <div class="pf-carousel">
    <div class="pf-track" id="pf-track">
      {portfolioItems.map((item) => (
        <article class="pf-item reveal">
          <Image src={item.img} alt={`Site web pour ${item.label}`} width={480} loading="lazy" />
          <span class="pf-item__label">{item.label}</span>
        </article>
      ))}
    </div>
    <div class="pf-nav">
      <button class="pf-nav__btn" id="pf-prev" aria-label="Précédent">
        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M13 7H1M5 3L1 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="pf-nav__btn" id="pf-next" aria-label="Suivant">
        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<section class="section wrap" id="resultats">
  <div class="section__head reveal">
    <span class="prompt">02 — <b>pour qui</b></span>
    <h2>Conçu pour ceux qui <em>vendent</em> en ligne.</h2>
  </div>
  <div class="who__grid">
    <article class="who-card reveal">
      <span class="who-card__k">coachs &amp; consultants</span>
      <h3>Un agenda qui se remplit seul</h3>
      <p>Un tunnel qui qualifie vos prospects et réserve les appels à votre place. Vous coachez, le système vend.</p>
    </article>
    <article class="who-card reveal">
      <span class="who-card__k">formateurs &amp; infopreneurs</span>
      <h3>La vente en automatique</h3>
      <p>Du clic à l'achat de votre formation, sans intervention manuelle. Lancez, mesurez, scalez.</p>
    </article>
    <article class="who-card reveal">
      <span class="who-card__k">e-commerçants</span>
      <h3>Plus de panier, moins d'abandon</h3>
      <p>Order bumps, upsells et relances automatiques pour faire monter chaque commande et récupérer les paniers perdus.</p>
    </article>
    <article class="who-card reveal">
      <span class="who-card__k">freelances &amp; studios</span>
      <h3>La partie technique, déléguée</h3>
      <p>Livrez des tunnels et des pages à vos propres clients sans embaucher ni vous arracher les cheveux sur le code.</p>
    </article>
  </div>
</section>

<section class="section wrap" id="services">
  <div class="section__head reveal">
    <span class="prompt">03 — <b>services</b></span>
    <h2>Quatre systèmes. Un seul objectif : <em>vendre</em>.</h2>
    <p class="lede" style="margin-top:1rem">On ne livre pas des pages. On livre des systèmes qui transforment un visiteur tiède en client qui passe à la caisse.</p>
  </div>
  <div class="svc__grid">
    <article class="card reveal">
      <span class="svc__no">01</span>
      <h3>Tunnels de vente</h3>
      <p class="svc__desc">Un parcours guidé, du premier clic au paiement, pensé pour faire monter chaque commande.</p>
      <ul class="deliver">
        <li>Page de capture optimisée pour l'opt-in</li>
        <li>Page de vente prête pour la vidéo (VSL)</li>
        <li>Order bumps, upsells &amp; downsells</li>
      </ul>
    </article>
    <article class="card reveal">
      <span class="svc__no">02</span>
      <h3>Landing pages haute conversion</h3>
      <p class="svc__desc">Une page, un objectif, zéro distraction. Structurée pour le clic suivant.</p>
      <ul class="deliver">
        <li>Copywriting orienté bénéfice (structure AIDA)</li>
        <li>Design responsive, chargement sous 2 secondes</li>
        <li>Variante A/B et suivi des événements clés</li>
      </ul>
    </article>
    <article class="card reveal">
      <span class="svc__no">03</span>
      <h3>Site web</h3>
      <p class="svc__desc">Une vitrine rapide, propre et prête pour le référencement.</p>
      <ul class="deliver">
        <li>Design sur mesure, responsive</li>
        <li>Structure optimisée pour le SEO</li>
        <li>Mise en ligne &amp; hébergement inclus</li>
      </ul>
    </article>
    <article class="card reveal">
      <span class="svc__no">04</span>
      <h3>SaaS sur mesure</h3>
      <p class="svc__desc">Votre propre logiciel, conçu et développé pour votre activité.</p>
      <ul class="deliver">
        <li>Cahier des charges &amp; architecture</li>
        <li>Développement de bout en bout</li>
        <li>Maintenance &amp; évolutions incluses</li>
      </ul>
    </article>
  </div>
</section>

<div class="tmo-cinematic"><section class="section wrap">
  <div class="section__head reveal">
    <span class="prompt">04 — <b>résultats clients</b></span>
    <h2>Des chiffres, <em>pas</em> des compliments.</h2>
    <p class="lede" style="margin-top:.8rem">Chaque témoignage correspond à un projet réel, des chiffres vérifiés, un client joignable.</p>
  </div>
  <div class="tmo__grid">
    <figure class="tmo reveal">
      <div class="tmo__head"><div class="stars" aria-label="Note 5 sur 5">★★★★★</div><span class="tmo__delta">+32 appels</span></div>
      <blockquote class="tmo__q">« Mon tunnel tourne tout seul. +32 appels qualifiés le premier mois, sans que je touche à rien. »</blockquote>
      <figcaption class="tmo__by">
        <span class="tmo__av" aria-hidden="true">S</span>
        <span><span class="tmo__name">Sofia M.</span><br><span class="tmo__role">Coach business · Lyon</span></span>
      </figcaption>
    </figure>
    <figure class="tmo reveal">
      <div class="tmo__head"><div class="stars" aria-label="Note 5 sur 5">★★★★★</div><span class="tmo__delta">1,2% → 4,8%</span></div>
      <blockquote class="tmo__q">« Page de vente livrée en 6 jours. On est passés de 1,2 % à 4,8 % de conversion sur le même trafic. »</blockquote>
      <figcaption class="tmo__by">
        <span class="tmo__av" aria-hidden="true">K</span>
        <span><span class="tmo__name">Karim B.</span><br><span class="tmo__role">Formateur · Casablanca</span></span>
      </figcaption>
    </figure>
    <figure class="tmo reveal">
      <div class="tmo__head"><div class="stars" aria-label="Note 5 sur 5">★★★★★</div><span class="tmo__delta">+28% panier</span></div>
      <blockquote class="tmo__q">« Les order bumps ont fait +28 % de panier moyen. Rentabilisé en deux semaines, chrono en main. »</blockquote>
      <figcaption class="tmo__by">
        <span class="tmo__av" aria-hidden="true">É</span>
        <span><span class="tmo__name">Émilie D.</span><br><span class="tmo__role">E-commerçante · Bruxelles</span></span>
      </figcaption>
    </figure>
  </div>
</section></div>

<section class="section wrap" id="processus">
  <div class="section__head reveal">
    <span class="prompt">05 — <b>processus</b></span>
    <h2>Quatre étapes. <em>Aucune</em> zone d'ombre.</h2>
    <p class="lede" style="margin-top:1rem">Vous savez ce qu'on construit, quand, et pourquoi. Pas de jargon, pas de facture surprise.</p>
  </div>
  <div class="steps">
    <article class="step reveal">
      <span class="step__no">01</span>
      <h3>Audit stratégique</h3>
      <p>On analyse votre offre, votre trafic et vos points de fuite. On vous dit ce qui bloque vos conversions, concrètement.</p>
      <span class="tag tag--free">Gratuit · 30 min</span>
    </article>
    <article class="step reveal">
      <span class="step__no">02</span>
      <h3>Plan d'action personnalisé</h3>
      <p>Une feuille de route claire : quoi construire, dans quel ordre, pour quel résultat chiffré attendu.</p>
      <span class="tag">Sous 48 h</span>
    </article>
    <article class="step reveal">
      <span class="step__no">03</span>
      <h3>Implémentation &amp; livraison</h3>
      <p>On construit, on intègre, on teste. Vous récupérez un système prêt à tourner, avec une prise en main vidéo.</p>
      <span class="tag">7 jours</span>
    </article>
    <article class="step reveal">
      <span class="step__no">04</span>
      <h3>Optimisation continue</h3>
      <p>On suit les chiffres après lancement et on ajuste ce qui fait grimper la conversion, mois après mois.</p>
      <span class="tag">En option</span>
    </article>
  </div>
</section>

<section class="section wrap" id="faq">
  <div class="faq__grid">
    <div class="reveal">
      <span class="prompt">06 — <b>faq</b></span>
      <h2>Les questions que vous vous posez déjà.</h2>
      <p class="lede" style="margin-top:1rem">Et si la vôtre n'y est pas, l'audit gratuit est là pour ça.</p>
    </div>
    <div class="faq__list reveal">
      <div class="acc">
        <button class="acc__btn" aria-expanded="false"><span>Vous travaillez avec quelles zones ?</span><span class="acc__sign" aria-hidden="true">+</span></button>
        <div class="acc__panel"><p>Partout dans le monde : Maroc, France, Belgique, Suisse, Canada et au-delà. Le travail se fait à 100 % à distance, et les décalages horaires sont gérés en amont dès le plan d'action.</p></div>
      </div>
      <div class="acc">
        <button class="acc__btn" aria-expanded="false"><span>Faut-il des compétences techniques de mon côté ?</span><span class="acc__sign" aria-hidden="true">+</span></button>
        <div class="acc__panel"><p>Aucune. Vous récupérez un système clé en main avec une prise en main vidéo. Vous gérez votre contenu et votre offre, on gère toute la technique derrière.</p></div>
      </div>
      <div class="acc">
        <button class="acc__btn" aria-expanded="false"><span>En combien de temps c'est livré ?</span><span class="acc__sign" aria-hidden="true">+</span></button>
        <div class="acc__panel"><p>Une landing page en 3 à 5 jours, un tunnel de vente complet en 7 jours ouvrés après validation du plan. Les délais sont fixés noir sur blanc avant de commencer.</p></div>
      </div>
      <div class="acc">
        <button class="acc__btn" aria-expanded="false"><span>Et si je n'ai pas encore d'offre claire ?</span><span class="acc__sign" aria-hidden="true">+</span></button>
        <div class="acc__panel"><p>C'est exactement le rôle de l'audit gratuit. On clarifie votre offre, votre promesse et votre prix avant de construire quoi que ce soit. On ne bâtit jamais sur du flou.</p></div>
      </div>
      <div class="acc">
        <button class="acc__btn" aria-expanded="false"><span>Vous offrez une garantie ?</span><span class="acc__sign" aria-hidden="true">+</span></button>
        <div class="acc__panel"><p>Les révisions sont incluses jusqu'à validation finale. Si le système livré ne correspond pas au plan validé ensemble, on corrige sans frais. Pas de surprise, pas de petites lignes.</p></div>
      </div>
    </div>
  </div>
</section>

<section class="final wrap" id="contact">
  <div class="final__box reveal">
    <span class="eyebrow">// prochaine étape</span>
    <h2>Votre prochain client est déjà sur votre site. Il attend juste une raison de <em>cliquer</em>.</h2>
    <div class="final__proof">
      <span><b>120+</b> entrepreneurs accompagnés dans le monde</span>
      <span><b>Audit gratuit</b> · réponse sous 24 h</span>
      <span>Livraison en <b>7 jours</b> · Sans engagement</span>
    </div>
    <div class="final__cta">
      <a href="/contact" class="btn">Réserver mon audit gratuit <span class="arr">→</span></a>
      <a href="/creations" class="btn btn--ghost">Voir les services</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .hero{padding-top:clamp(2.5rem,6vw,4.5rem);padding-bottom:var(--section)}
  .hero__badge{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--mono);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--txt);border:1px solid var(--line);border-radius:100px;padding:.45rem .9rem;background:var(--panel)}
  .hero__badge .live{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--lime);box-shadow:0 0 0 0 rgba(199,247,62,.6);animation:pulse 2.4s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(199,247,62,.55)}70%{box-shadow:0 0 0 9px rgba(199,247,62,0)}100%{box-shadow:0 0 0 0 rgba(199,247,62,0)}}

  .hero__grid{display:grid;grid-template-columns:1.5fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:end;margin-top:2.2rem}
  .hero h1{font-size:clamp(1.9rem,4vw,3.4rem);font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:1.05;margin-top:.5rem}
  .hero h1 em{font-style:normal;color:var(--lime)}
  .hero__sub{margin-top:1.6rem;max-width:46ch}
  .hero__cta{margin-top:2.1rem;display:flex;flex-wrap:wrap;gap:1rem 1.4rem;align-items:center}
  .hero__micro{font-family:var(--mono);font-size:.76rem;color:var(--muted);letter-spacing:.03em;display:flex;align-items:center;gap:.5rem}
  .hero__micro b{color:var(--lime);font-weight:700}

  .console{background:var(--panel);border:1px solid var(--line);border-radius:6px;overflow:hidden;box-shadow:0 30px 60px -30px rgba(0,0,0,.8)}
  .console__bar{display:flex;align-items:center;gap:.5rem;padding:.7rem 1rem;border-bottom:1px solid var(--line);background:var(--panel-2)}
  .console__dot{width:9px;height:9px;border-radius:50%;background:var(--line-2)}
  .console__dot.on{background:var(--lime)}
  .console__name{font-family:var(--mono);font-size:.72rem;color:var(--muted);letter-spacing:.06em;margin-left:auto}
  .console__body{padding:1.3rem 1.4rem 1.5rem}
  .metric{padding:.9rem 0;border-bottom:1px dashed var(--line)}
  .metric:last-child{border-bottom:0;padding-bottom:.2rem}
  .metric__top{display:flex;justify-content:space-between;align-items:baseline;gap:1rem}
  .metric__label{font-family:var(--mono);font-size:.74rem;color:var(--muted);letter-spacing:.02em}
  .metric__val{font-family:var(--display);font-weight:800;font-size:clamp(1.7rem,2.6vw,2.3rem);line-height:1;color:var(--txt)}
  .metric__val .u{font-family:var(--mono);font-size:.55em;color:var(--lime);font-weight:700;vertical-align:super}
  .metric__bar{height:5px;background:#202024;border-radius:100px;margin-top:.7rem;overflow:hidden}
  .metric__fill{height:100%;width:0;background:var(--lime);border-radius:100px;transition:width 1.2s var(--ease)}

  @media (max-width:880px){.hero__grid{grid-template-columns:1fr;align-items:start;gap:2.4rem}}

  .svc__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
  .svc__no{font-family:var(--mono);font-size:.74rem;letter-spacing:.06em;color:var(--lime);text-transform:uppercase}
  .card h3{font-size:1.3rem;font-weight:800;margin:.6rem 0 .6rem;letter-spacing:-.02em}
  .svc__desc{color:var(--muted);font-size:.92rem}
  .deliver{list-style:none;margin:1.2rem 0 0;border-top:1px solid var(--line)}
  .deliver li{display:flex;gap:.6rem;align-items:flex-start;padding:.65rem 0;border-bottom:1px solid var(--line);font-size:.86rem}
  .deliver li::before{content:"+";color:var(--lime);font-family:var(--mono);font-weight:700;flex:none}

  @media (max-width:880px){.svc__grid{grid-template-columns:1fr 1fr}}
  @media (max-width:520px){.svc__grid{grid-template-columns:1fr}}

  .pf-carousel{position:relative}
  .pf-track{display:flex;gap:1.2rem;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;padding-bottom:.4rem;-webkit-overflow-scrolling:touch}
  .pf-track::-webkit-scrollbar{display:none}
  .pf-item{flex:0 0 clamp(240px,32vw,340px);scroll-snap-align:start;background:var(--panel);border:1px solid var(--line);border-radius:6px;overflow:hidden;transition:border-color .3s var(--ease),transform .3s var(--ease)}
  .pf-item:hover{border-color:var(--lime);transform:translateY(-4px)}
  .pf-item img{width:100%;height:260px;object-fit:contain;background:var(--void);display:block}
  .pf-item__label{display:block;font-family:var(--mono);font-size:.78rem;letter-spacing:.03em;text-transform:uppercase;color:var(--txt);padding:.9rem 1rem}
  .pf-nav{display:flex;gap:.6rem;justify-content:flex-end;margin-top:1.2rem}
  .pf-nav__btn{background:none;border:1px solid var(--line-2);color:var(--txt);width:42px;height:42px;border-radius:4px;display:grid;place-items:center;cursor:pointer;transition:.2s}
  .pf-nav__btn:hover{border-color:var(--lime);color:var(--lime)}

  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .step{border-top:2px solid var(--line-2);padding:1.4rem 1.4rem 1.4rem 0;position:relative;transition:border-color .3s}
  .steps .step{border-right:1px solid var(--line);padding-inline:1.4rem}
  .steps .step:first-child{padding-left:0}
  .steps .step:last-child{border-right:0}
  .step:hover{border-top-color:var(--lime)}
  .step__no{font-family:var(--mono);font-size:.8rem;color:var(--lime);letter-spacing:.06em;font-weight:700}
  .step h3{font-size:1.3rem;margin:.9rem 0 .6rem;font-weight:800;letter-spacing:-.02em}
  .step p{font-size:.9rem;color:var(--muted);margin-bottom:1.1rem}
  @media (max-width:880px){.steps{grid-template-columns:1fr 1fr}.steps .step:nth-child(2){border-right:0}}
  @media (max-width:520px){.steps{grid-template-columns:1fr}.steps .step{border-right:0!important;padding-inline:0}}

  .who__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
  .who-card{border:1px solid var(--line);border-radius:6px;padding:1.5rem;transition:.3s var(--ease)}
  .who-card:hover{border-color:var(--lime);background:var(--panel)}
  .who-card__k{font-family:var(--mono);font-size:.72rem;color:var(--lime);letter-spacing:.04em;text-transform:uppercase}
  .who-card h3{font-size:1.28rem;margin:.7rem 0 .6rem;font-weight:800;letter-spacing:-.02em}
  .who-card p{font-size:.92rem;color:var(--muted)}
  @media (max-width:880px){.who__grid{grid-template-columns:1fr 1fr}}
  @media (max-width:520px){.who__grid{grid-template-columns:1fr}}

  .tmo__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
  .tmo{background:var(--panel);border:1px solid var(--line);border-radius:6px;padding:1.8rem;display:flex;flex-direction:column;gap:1.1rem;transition:.3s var(--ease)}
  .tmo:hover{transform:translateY(-4px);border-color:var(--line-2)}
  .tmo__head{display:flex;justify-content:space-between;align-items:center}
  .stars{color:var(--lime);letter-spacing:.15em;font-size:.9rem}
  .tmo__delta{font-family:var(--mono);font-size:.72rem;color:var(--lime);border:1px solid var(--line-2);border-radius:100px;padding:.25rem .55rem}
  .tmo__q{font-size:1.12rem;line-height:1.45;font-weight:500}
  .tmo__by{margin-top:auto;display:flex;align-items:center;gap:.85rem;border-top:1px solid var(--line);padding-top:1rem}
  .tmo__av{width:42px;height:42px;border-radius:50%;background:var(--lime);color:var(--void);display:grid;place-items:center;font-family:var(--display);font-weight:900;font-size:1rem;flex:none}
  .tmo__name{font-weight:700;font-size:.95rem}
  .tmo__role{font-family:var(--mono);font-size:.72rem;color:var(--muted)}
  @media (max-width:880px){.tmo__grid{grid-template-columns:1fr}}

  /* ── cinematic sections ── */
  .cinematic{position:relative}
  .cinematic::before{content:"";position:absolute;inset:0;z-index:0;pointer-events:none}
  .tmo-cinematic{background:linear-gradient(rgba(14,14,16,.87),rgba(14,14,16,.87)),url('https://images.unsplash.com/photo-1551434678-e076c223a692?w=1920&q=80&fit=crop') center/cover no-repeat;border-block:1px solid rgba(199,247,62,.1)}

  .faq__grid{display:grid;grid-template-columns:1fr 1.4fr;gap:clamp(2rem,5vw,4rem);align-items:start}
  .faq__list{border-top:1px solid var(--line-2)}
  .acc{border-bottom:1px solid var(--line)}
  .acc__btn{width:100%;background:none;border:0;cursor:pointer;text-align:left;display:flex;justify-content:space-between;gap:1.5rem;align-items:center;padding:1.4rem 0;font-family:var(--display);font-size:clamp(1.05rem,2vw,1.32rem);font-weight:700;color:var(--txt);letter-spacing:-.01em}
  .acc__sign{font-family:var(--mono);color:var(--lime);font-size:1.3rem;flex:none;transition:transform .3s var(--ease)}
  .acc.is-open .acc__sign{transform:rotate(45deg)}
  .acc__panel{overflow:hidden;max-height:0;transition:max-height .4s var(--ease)}
  .acc__panel p{padding:0 0 1.4rem;color:var(--muted);max-width:60ch}
  .acc__btn:focus-visible{outline:2px solid var(--lime);outline-offset:3px}
  @media (max-width:880px){.faq__grid{grid-template-columns:1fr}}

  .final{padding-block:var(--section)}
  .final__box{background:var(--lime);color:var(--void);border-radius:8px;padding:clamp(2.4rem,6vw,5rem);position:relative;overflow:hidden}
  .final__box::after{content:"";position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(14,14,16,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(14,14,16,.07) 1px,transparent 1px);background-size:40px 40px}
  .final__box>*{position:relative;z-index:1}
  .final .eyebrow{font-family:var(--mono);font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(14,14,16,.65)}
  .final h2{color:var(--void);max-width:18ch}
  .final h2 em{font-style:normal;color:var(--void);text-decoration:underline;text-decoration-thickness:3px;text-underline-offset:5px}
  .final__proof{font-family:var(--mono);font-size:.78rem;letter-spacing:.02em;color:rgba(14,14,16,.8);margin-top:1.6rem;display:flex;flex-wrap:wrap;gap:.5rem 1.4rem}
  .final__proof b{color:var(--void);font-weight:700}
  .final__cta{margin-top:2.2rem;display:flex;flex-wrap:wrap;gap:1rem}
  .final .btn{--bg:var(--void);--fg:var(--lime);--bd:var(--void)}
  .final .btn:hover{box-shadow:0 14px 30px -14px rgba(14,14,16,.6)}
  .final .btn--ghost{--bg:transparent;--fg:var(--void);--bd:rgba(14,14,16,.4)}
  .final .btn--ghost:hover{--bd:var(--void);box-shadow:none}

  #services,#processus,#resultats,#faq,#contact,#portfolio{scroll-margin-top:82px}
</style>

<script>
(function(){
  "use strict";
  var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll('a[href^="#"]').forEach(function(a){
    a.addEventListener("click", function(e){
      var t = document.querySelector(this.getAttribute("href"));
      if(t){ e.preventDefault(); t.scrollIntoView({behavior: reduce ? "instant" : "smooth"}); }
    });
  });

  /* carrousel portfolio */
  (function(){
    var track = document.getElementById("pf-track");
    var prev = document.getElementById("pf-prev");
    var next = document.getElementById("pf-next");
    if(!track || !prev || !next) return;
    function step(){
      var item = track.querySelector(".pf-item");
      return item ? item.getBoundingClientRect().width + 19 : 300;
    }
    prev.addEventListener("click", function(){
      track.scrollBy({left: -step(), behavior: reduce ? "instant" : "smooth"});
    });
    next.addEventListener("click", function(){
      track.scrollBy({left: step(), behavior: reduce ? "instant" : "smooth"});
    });
  })();

  /* barres de progression — même pattern que résultats.live (a-propos) */
  (function(){
    var fills = document.querySelectorAll(".metric__fill[data-w]");
    if(!fills.length) return;
    if(reduce || !("IntersectionObserver" in window)){
      fills.forEach(function(el){ el.style.width = el.getAttribute("data-w") + "%"; });
      return;
    }
    var barIO = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.style.width = e.target.getAttribute("data-w") + "%"; barIO.unobserve(e.target); }
      });
    }, {threshold:.3});
    fills.forEach(function(el){ barIO.observe(el); });
  })();

  var reveals = document.querySelectorAll(".reveal");
  if(reduce || !("IntersectionObserver" in window)){
    reveals.forEach(function(el){ el.classList.add("in"); });
  } else {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          var sibs = Array.prototype.slice.call(e.target.parentNode.querySelectorAll(":scope > .reveal"));
          var i = sibs.indexOf(e.target);
          var delay = Math.min(i,5)*70;
          e.target.style.transitionDelay = delay + "ms";
          e.target.classList.add("in");
          io.unobserve(e.target);
          (function(el,d){ setTimeout(function(){ el.style.transitionDelay = ""; }, d + 750); })(e.target, delay);
        }
      });
    }, {threshold:.16, rootMargin:"0px 0px -8% 0px"});
    reveals.forEach(function(el){ io.observe(el); });
  }

  var accs = document.querySelectorAll(".acc__btn");
  accs.forEach(function(btn){
    btn.addEventListener("click", function(){
      var acc = btn.parentNode, panel = btn.nextElementSibling;
      var open = acc.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      panel.style.maxHeight = open ? panel.scrollHeight + "px" : null;
    });
  });

  window.addEventListener("resize", function(){
    document.querySelectorAll(".acc.is-open .acc__panel").forEach(function(panel){
      panel.style.maxHeight = panel.scrollHeight + "px";
    });
  }, {passive:true});
})();
</script>
